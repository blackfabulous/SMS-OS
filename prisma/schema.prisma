  staffId      String
  incidentType String
  description  String
  date         DateTime
  action       String?
  status       String   @default("OPEN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  staff     Staff     @relation(fields: [staffId], references: [id])
  deletedAt DateTime?

  @@index([deletedAt])
}

