enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  BURSAR
  PARENT
  STUDENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EnrollmentStatus {
  ACTIVE
  PENDING
  GRADUATED
  TRANSFERRED
  DROPPED_OUT
  SUSPENDED
  EXPELLED
}

