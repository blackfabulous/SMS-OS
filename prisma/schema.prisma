// Zimbabwe School Management System - Database Schema
// Targets PostgreSQL (Supabase managed Postgres) with comprehensive school operations support

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection (PgBouncer, port 6543, ?pgbouncer=true)
  directUrl = env("DIRECT_URL") // direct connection (port 5432) — used for schema ops/migrations
}

// ============================================
// 1. FOUNDATION - School & Academic Structure
// ============================================

model School {
  id                   String             @id @default(cuid())
  name                 String
  code                 String             @unique
  motto                String?
  logo                 String?
  zimsecCentreNumber   String?
  mopseDistrict        String?
  province             String
  schoolType           SchoolType         @default(GOVERNMENT)
  ownershipType        OwnershipType      @default(GOVERNMENT)
  levelType            SchoolLevelType    @default(PRIMARY)
  registrationStatus   RegistrationStatus @default(REGISTERED)
  headName             String?
  deputyHeadName       String?
  contactEmail         String?
  contactPhone         String?
  physicalAddress      String?
  gpsLatitude          String?
  gpsLongitude         String?
  catchmentArea        String?
  responsibleAuthority String?
  establishedYear      Int?
  isActive             Boolean            @default(true)
  bankName             String?
  bankAccountNumber    String?
  bankBranch           String?
  taxNumber            String?
  nssaNumber           String?
  zimdefNumber         String?
  sdcChairperson       String?
  sdcSecretary         String?
  sdcTreasurer         String?
  createdAt            DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime           @updatedAt @db.Timestamptz(3)

  academicYears           AcademicYear[]
  grades                  Grade[]
  subjects                Subject[]
  departments             Department[]
  students                Student[]
  staffMembers            Staff[]
  parents                 Parent[]
  feeStructures           FeeStructure[]
  bankAccounts            BankAccount[]
  houses                  House[]
  hostels                 Hostel[]
  transportRoutes         TransportRoute[]
  vehicles                Vehicle[]
  assets                  Asset[]
  suppliers               Supplier[]
  libraryBooks            LibraryBook[]
  sdcMembers              SDCMember[]
  events                  SchoolEvent[]
  clubs                   Club[]
  sportsCodes             SportsCode[]
  users                   User[]
  canteenItems            CanteenItem[]
  canteenTransactions     CanteenTransaction[]
  purchaseOrders          PurchaseOrder[]
  requisitions            Requisition[]
  documents               Document[]
  alumni                  Alumni[]
  visitors                Visitor[]
  securityIncidents       SecurityIncident[]
  courses                 Course[]
  timetableEntries        TimetableEntry[]
  websitePages            WebsitePage[]
  newsArticles            NewsArticle[]
  galleryImages           GalleryImage[]
  shopItems               SchoolShopItem[]
  shopOrders              SchoolShopOrder[]
  seoSettings             SEOSetting[]
  settings                SchoolSetting[]
  partners                Partner[]
  siteTheme               SiteTheme?
  faqs                    Faq[]
  notificationLogs        NotificationLog[]
  notificationTemplates   NotificationTemplate[]
  auditLogs               AuditLog[]
  outboxMessages          Outbox[]
  feeInvoices             FeeInvoice[]
  feePayments             FeePayment[]
  invoiceItems            InvoiceItem[]
  paymentAllocations      PaymentAllocation[]
  terms                   Term[]
  gradeSubjects           GradeSubject[]
  studentParents          StudentParent[]
  studentEnrollments      StudentEnrollment[]
  attendances             Attendance[]
  assessmentMarks         AssessmentMark[]
  reportCards             ReportCard[]
  scholarships            Scholarship[]
  zimsecCandidates        ZimsecCandidate[]
  beamApplications        BeamApplication[]
  welfareRecords          WelfareRecord[]
  disciplineRecords       DisciplineRecord[]
  healthRecords           HealthRecord[]
  dormitories             Dormitory[]
  boardingAssignments     BoardingAssignment[]
  transportAssignments    TransportAssignment[]
  libraryTransactions     LibraryTransaction[]
  payslips                Payslip[]
  leaveRecords            LeaveRecord[]
  appraisalRecords        AppraisalRecord[]
  staffDisciplines        StaffDiscipline[]
  alumniContributions     AlumniContribution[]
  courseResources         CourseResource[]
  courseAssignments       CourseAssignment[]
  canteenTransactionItems CanteenTransactionItem[]
  purchaseOrderItems      PurchaseOrderItem[]
}

model NotificationLog {
  id           String              @id @default(cuid())
  schoolId     String
  channel      NotificationChannel @default(SMS)
  recipients   Int                 @default(1)
  subject      String?
  body         String
  status       NotificationStatus  @default(DELIVERED)
  deliveryRate Float               @default(100)
  phone        String?
  eventType    String?
  createdAt    DateTime            @default(now()) @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([schoolId, createdAt])
  @@index([deletedAt])
}

model NotificationTemplate {
  id         String    @id @default(cuid())
  schoolId   String
  name       String
  category   String    @default("General")
  channels   String    @default("SMS")
  subject    String?
  body       String
  usageCount Int       @default(0)
  lastUsed   DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([schoolId])
  @@index([deletedAt])
}

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  startDate DateTime @db.Timestamptz(3)
  endDate   DateTime @db.Timestamptz(3)
  isCurrent Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  school             School              @relation(fields: [schoolId], references: [id])
  terms              Term[]
  studentEnrollments StudentEnrollment[]
  deletedAt          DateTime?           @db.Timestamptz(3)

  @@unique([schoolId, name])
  @@index([deletedAt])
}

model Term {
  id             String    @id @default(cuid())
  academicYearId String
  name           String
  termNumber     Int
  startDate      DateTime  @db.Timestamptz(3)
  endDate        DateTime  @db.Timestamptz(3)
  openingDate    DateTime? @db.Timestamptz(3)
  closingDate    DateTime? @db.Timestamptz(3)
  isCurrent      Boolean   @default(false)
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(3)

  schoolId          String
  school            School       @relation(fields: [schoolId], references: [id])
  academicYear      AcademicYear @relation(fields: [academicYearId], references: [id])
  attendanceRecords Attendance[]
  assessments       Assessment[]
  feeInvoices       FeeInvoice[]
  deletedAt         DateTime?    @db.Timestamptz(3)

  @@unique([academicYearId, termNumber])
  @@index([deletedAt])
  @@index([schoolId])
}

model Grade {
  id        String        @id @default(cuid())
  schoolId  String
  name      String
  level     AcademicLevel @default(PRIMARY)
  sequence  Int
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt DateTime      @updatedAt @db.Timestamptz(3)

  school        School         @relation(fields: [schoolId], references: [id])
  classes       Class[]
  gradeSubjects GradeSubject[]
  feeStructures FeeStructure[]
  deletedAt     DateTime?      @db.Timestamptz(3)

  @@unique([schoolId, name])
  @@index([deletedAt])
}

model Class {
  id             String   @id @default(cuid())
  schoolId       String
  gradeId        String
  name           String
  stream         String?
  academicYear   String
  capacity       Int      @default(40)
  classTeacherId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)

  grade            Grade               @relation(fields: [gradeId], references: [id])
  enrollments      StudentEnrollment[]
  timetableEntries TimetableEntry[]
  deletedAt        DateTime?           @db.Timestamptz(3)

  @@unique([schoolId, gradeId, name, academicYear])
  @@index([deletedAt])
}

model Subject {
  id          String   @id @default(cuid())
  schoolId    String
  code        String
  name        String
  department  String?
  isCore      Boolean  @default(false)
  isPractical Boolean  @default(false)
  passMark    Float    @default(50)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  school           School           @relation(fields: [schoolId], references: [id])
  gradeSubjects    GradeSubject[]
  assessments      Assessment[]
  timetableEntries TimetableEntry[]
  deletedAt        DateTime?        @db.Timestamptz(3)

  @@unique([schoolId, code])
  @@index([deletedAt])
}

model GradeSubject {
  id             String   @id @default(cuid())
  gradeId        String
  subjectId      String
  isCompulsory   Boolean  @default(true)
  periodsPerWeek Int      @default(5)
  createdAt      DateTime @default(now()) @db.Timestamptz(3)

  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id])
  grade     Grade     @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  subject   Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  deletedAt DateTime? @db.Timestamptz(3)

  @@unique([gradeId, subjectId])
  @@index([deletedAt])
  @@index([schoolId])
}

model Department {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  headId    String?
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
}

// ============================================
// 2. LEARNER MANAGEMENT
// ============================================

model Student {
  id                  String           @id @default(cuid())
  schoolId            String
  studentNumber       String
  firstName           String
  lastName            String
  middleName          String?
  preferredName       String?
  dateOfBirth         DateTime         @db.Timestamptz(3)
  gender              Gender
  birthCertNumber     String?
  nationalId          String?
  passportNumber      String?
  photo               String?
  religion            String?
  homeLanguage        String?
  languagePreference  String           @default("ENGLISH")
  nationality         String           @default("Zimbabwean")
  bloodGroup          String?
  allergies           String?
  chronicConditions   String?
  medications         String?
  doctorName          String?
  doctorPhone         String?
  enrollmentStatus    EnrollmentStatus @default(ACTIVE)
  boardingStatus      BoardingStatus?
  beamStatus          BeamStatus?
  isSpecialNeeds      Boolean          @default(false)
  specialNeedsDetails String?
  previousSchool      String?
  admissionDate       DateTime         @default(now()) @db.Timestamptz(3)
  transferDate        DateTime?        @db.Timestamptz(3)
  exitDate            DateTime?        @db.Timestamptz(3)
  exitReason          String?
  createdAt           DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime         @updatedAt @db.Timestamptz(3)

  school              School               @relation(fields: [schoolId], references: [id])
  parentLinks         StudentParent[]
  enrollments         StudentEnrollment[]
  attendanceRecords   Attendance[]
  assessmentMarks     AssessmentMark[]
  feeInvoices         FeeInvoice[]
  feePayments         FeePayment[]
  disciplineRecords   DisciplineRecord[]
  healthRecords       HealthRecord[]
  welfareRecords      WelfareRecord[]
  beamApplication     BeamApplication?
  scholarships        Scholarship[]
  libraryTransactions LibraryTransaction[]
  transportAssignment TransportAssignment?
  boardingAssignment  BoardingAssignment?
  reportCards         ReportCard[]
  zimsecCandidate     ZimsecCandidate?
  user                User?
  deletedAt           DateTime?            @db.Timestamptz(3)

  @@unique([schoolId, studentNumber])
  @@index([schoolId])
  @@index([enrollmentStatus])
  @@index([schoolId, enrollmentStatus])
  @@index([deletedAt])
}

model Parent {
  id               String         @id @default(cuid())
  schoolId         String
  title            String?
  firstName        String
  lastName         String
  nationalId       String?
  email            String?
  phone            String
  whatsappNumber   String?
  address          String?
  employer         String?
  occupation       String?
  preferredContact ContactChannel @default(SMS)
  isFeeResponsible Boolean        @default(false)
  createdAt        DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime       @updatedAt @db.Timestamptz(3)

  school         School          @relation(fields: [schoolId], references: [id])
  studentLinks   StudentParent[]
  feePayments    FeePayment[]
  communications Communication[]
  user           User?
  deletedAt      DateTime?       @db.Timestamptz(3)

  @@index([schoolId])
  @@index([phone])
  @@index([deletedAt])
}

model StudentParent {
  id                  String   @id @default(cuid())
  studentId           String
  parentId            String
  relationship        String
  isPrimary           Boolean  @default(false)
  isFeeResponsible    Boolean  @default(false)
  hasPickupPermission Boolean  @default(true)
  hasCustody          Boolean  @default(true)
  custodyRestrictions String?
  createdAt           DateTime @default(now()) @db.Timestamptz(3)

  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent    Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  deletedAt DateTime? @db.Timestamptz(3)

  @@unique([studentId, parentId])
  @@index([deletedAt])
  @@index([schoolId])
}

model StudentEnrollment {
  id             String           @id @default(cuid())
  studentId      String
  classId        String
  academicYearId String
  enrollmentDate DateTime         @default(now()) @db.Timestamptz(3)
  exitDate       DateTime?        @db.Timestamptz(3)
  status         EnrollmentStatus @default(ACTIVE)
  createdAt      DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @db.Timestamptz(3)

  schoolId     String
  school       School       @relation(fields: [schoolId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  deletedAt    DateTime?    @db.Timestamptz(3)

  @@unique([studentId, academicYearId])
  @@index([classId, academicYearId])
  @@index([deletedAt])
  @@index([schoolId])
}

// ============================================
// 3. STAFF & HR
// ============================================

model Staff {
  id                      String        @id @default(cuid())
  schoolId                String
  staffNumber             String
  title                   String?
  firstName               String
  lastName                String
  middleName              String?
  nationalId              String?
  dateOfBirth             DateTime?     @db.Timestamptz(3)
  gender                  Gender?
  address                 String?
  phone                   String?
  email                   String?
  nextOfKin               String?
  nextOfKinPhone          String?
  position                String
  department              String?
  staffType               StaffType     @default(TEACHING)
  payType                 PayType       @default(SCHOOL_PAID)
  qualifications          String?
  subjectSpecialisation   String?
  employmentDate          DateTime?     @db.Timestamptz(3)
  contractType            ContractType  @default(PERMANENT)
  payrollStatus           PayrollStatus @default(ACTIVE)
  bankName                String?
  bankAccountNumber       String?
  nssaNumber              String?
  taxNumber               String?
  basicSalary             Decimal       @default(0) @db.Decimal(15, 2)
  housingAllowance        Decimal       @default(0) @db.Decimal(15, 2)
  transportAllowance      Decimal       @default(0) @db.Decimal(15, 2)
  responsibilityAllowance Decimal       @default(0) @db.Decimal(15, 2)
  photo                   String?
  isActive                Boolean       @default(true)
  // Public website ("Our team" on the About page)
  showOnWebsite           Boolean       @default(false)
  websiteBio              String?
  websiteOrder            Int           @default(0)
  createdAt               DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime      @updatedAt @db.Timestamptz(3)

  school              School            @relation(fields: [schoolId], references: [id])
  leaveRecords        LeaveRecord[]
  payslips            Payslip[]
  appraisalRecords    AppraisalRecord[]
  disciplinaryRecords StaffDiscipline[]
  user                User?
  deletedAt           DateTime?         @db.Timestamptz(3)

  @@unique([schoolId, staffNumber])
  @@index([deletedAt])
}

// ============================================
// 4. ATTENDANCE
// ============================================

model Attendance {
  id             String           @id @default(cuid())
  studentId      String?
  termId         String
  date           DateTime         @db.Timestamptz(3)
  attendanceType AttendanceType   @default(DAILY)
  status         AttendanceStatus @default(PRESENT)
  remarks        String?
  createdAt      DateTime         @default(now()) @db.Timestamptz(3)

  student   Student?  @relation(fields: [studentId], references: [id])
  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id])
  term      Term      @relation(fields: [termId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([studentId, date])
  @@index([termId])
  @@index([termId, date])
  @@index([deletedAt])
  @@index([schoolId])
}

// ============================================
// 5. ASSESSMENT & ACADEMICS
// ============================================

model Assessment {
  id             String         @id @default(cuid())
  schoolId       String
  termId         String
  subjectId      String
  classId        String?
  name           String
  assessmentType AssessmentType @default(TEST)
  totalMarks     Float          @default(100)
  weight         Float          @default(1)
  date           DateTime?      @db.Timestamptz(3)
  isLocked       Boolean        @default(false)
  createdAt      DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime       @updatedAt @db.Timestamptz(3)

  subject   Subject          @relation(fields: [subjectId], references: [id])
  term      Term             @relation(fields: [termId], references: [id])
  marks     AssessmentMark[]
  deletedAt DateTime?        @db.Timestamptz(3)

  @@index([deletedAt])
}

model AssessmentMark {
  id            String   @id @default(cuid())
  assessmentId  String
  studentId     String
  marksObtained Float
  grade         String?
  comments      String?
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)

  schoolId   String
  school     School     @relation(fields: [schoolId], references: [id])
  assessment Assessment @relation(fields: [assessmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])
  deletedAt  DateTime?  @db.Timestamptz(3)

  @@unique([assessmentId, studentId])
  @@index([studentId])
  @@index([deletedAt])
  @@index([schoolId])
}

model ReportCard {
  id                   String           @id @default(cuid())
  studentId            String
  termId               String
  classId              String
  overallGrade         String?
  overallPosition      Int?
  classTeacherComment  String?
  headComment          String?
  attendanceDays       Int?
  daysPresent          Int?
  status               ReportCardStatus @default(DRAFT)
  classTeacherSignedAt DateTime?        @db.Timestamptz(3)
  headSignedAt         DateTime?        @db.Timestamptz(3)
  isPublished          Boolean          @default(false)
  createdAt            DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime         @updatedAt @db.Timestamptz(3)

  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@unique([studentId, termId])
  @@index([classId, termId])
  @@index([deletedAt])
  @@index([schoolId])
}

// ============================================
// 6. FINANCE
// ============================================

model FeeStructure {
  id        String   @id @default(cuid())
  schoolId  String
  gradeId   String
  termId    String?
  name      String
  feeType   String
  amount    Decimal  @db.Decimal(15, 2)
  currency  Currency @default(USD)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  grade     Grade     @relation(fields: [gradeId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
}

model FeeInvoice {
  id             String        @id @default(cuid())
  studentId      String
  termId         String
  schoolId       String
  invoiceNumber  String
  totalAmount    Decimal       @db.Decimal(15, 2)
  amountPaid     Decimal       @default(0) @db.Decimal(15, 2)
  balance        Decimal       @db.Decimal(15, 2)
  dueDate        DateTime      @db.Timestamptz(3)
  status         InvoiceStatus @default(PENDING)
  lateFeeApplied Boolean       @default(false) // guards against compounding the overdue penalty
  createdAt      DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(3)

  student     Student             @relation(fields: [studentId], references: [id])
  term        Term                @relation(fields: [termId], references: [id])
  school      School              @relation(fields: [schoolId], references: [id])
  allocations PaymentAllocation[]
  payments    FeePayment[]
  items       InvoiceItem[]
  deletedAt   DateTime?           @db.Timestamptz(3)

  @@unique([schoolId, invoiceNumber])
  @@index([studentId, status])
  @@index([termId])
  @@index([deletedAt])
  @@index([schoolId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  amount      Decimal  @db.Decimal(15, 2)
  feeType     String
  schoolId    String
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  invoice   FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  school    School     @relation(fields: [schoolId], references: [id])
  deletedAt DateTime?  @db.Timestamptz(3)

  @@index([deletedAt])
  @@index([schoolId])
}

model FeePayment {
  id            String        @id @default(cuid())
  studentId     String
  invoiceId     String?
  parentId      String?
  schoolId      String
  receiptNumber String
  amount        Decimal       @db.Decimal(15, 2)
  paymentMethod PaymentMethod @default(CASH)
  currency      Currency      @default(USD)
  exchangeRate  Decimal       @default(1) @db.Decimal(15, 6)
  reference     String?
  isReversed    Boolean       @default(false)
  createdAt     DateTime      @default(now()) @db.Timestamptz(3)

  student     Student             @relation(fields: [studentId], references: [id])
  invoice     FeeInvoice?         @relation(fields: [invoiceId], references: [id])
  parent      Parent?             @relation(fields: [parentId], references: [id])
  school      School              @relation(fields: [schoolId], references: [id])
  allocations PaymentAllocation[]
  deletedAt   DateTime?           @db.Timestamptz(3)

  @@unique([schoolId, receiptNumber])
  @@index([studentId])
  @@index([invoiceId])
  @@index([parentId])
  @@index([deletedAt])
  @@index([schoolId])
}

model PaymentAllocation {
  id          String    @id @default(cuid())
  paymentId   String
  invoiceId   String
  schoolId    String
  amount      Decimal   @db.Decimal(15, 2)
  allocatedAt DateTime  @default(now()) @db.Timestamptz(3)
  deletedAt   DateTime? @db.Timestamptz(3)

  payment FeePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  school  School     @relation(fields: [schoolId], references: [id])

  @@index([paymentId])
  @@index([invoiceId])
  @@index([schoolId])
  @@index([deletedAt])
}

model BankAccount {
  id            String      @id @default(cuid())
  schoolId      String
  bankName      String
  accountName   String
  accountNumber String
  branch        String?
  branchCode    String?
  accountType   AccountType @default(CURRENT)
  currency      Currency    @default(USD)
  balance       Decimal     @default(0) @db.Decimal(15, 2)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now()) @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
