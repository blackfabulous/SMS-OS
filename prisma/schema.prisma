  CANCELLED
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(ADMIN)
  staffId   String?   @unique
  studentId String?   @unique
  parentId  String?
  schoolId  String
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  staff     Staff?    @relation(fields: [staffId], references: [id])
  student   Student?  @relation(fields: [studentId], references: [id])
  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime?

  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

// ============================================
// 20. AUDIT LOG
// ============================================

model AuditLog {
  id          String    @id @default(cuid())
  schoolId    String?
  action      String
  entity      String
  entityId    String?
  performedBy String?
  actorId     String?
  details     String?
  beforeValue Json?
  afterValue  Json?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([schoolId])
}

model Outbox {
  id          String    @id @default(cuid())
  schoolId    String?
  topic       String
  payload     Json
  status      String    @default("PENDING")
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  error       String?
  scheduledAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  school      School?   @relation(fields: [schoolId], references: [id])

  @@index([status, scheduledAt])
  @@index([schoolId])
  @@index([deletedAt])
}

// ============================================
// 20. CANTEEN / TUCKSHOP
// ============================================

model CanteenItem {
  id            String   @id @default(cuid())
  schoolId      String
  name          String
  category      String   @default("FOOD")
  price         Decimal  @default(0) @db.Decimal(15, 2)
  costPrice     Decimal  @default(0) @db.Decimal(15, 2)
  stockQuantity Int      @default(0)
  reorderLevel  Int      @default(5)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school           School                   @relation(fields: [schoolId], references: [id])
  transactionItems CanteenTransactionItem[]
  deletedAt        DateTime?

  @@index([deletedAt])
}

model CanteenTransaction {
  id                String        @id @default(cuid())
  schoolId          String
  transactionNumber String        @unique
  buyerType         String        @default("STUDENT")
  buyerId           String?
  buyerName         String
  totalAmount       Decimal       @default(0) @db.Decimal(15, 2)
  paymentMethod     PaymentMethod @default(CASH)
  status            String        @default("COMPLETED")
  createdAt         DateTime      @default(now())

  school    School                   @relation(fields: [schoolId], references: [id])
  items     CanteenTransactionItem[]
  deletedAt DateTime?

  @@index([deletedAt])
}

model CanteenTransactionItem {
  id            String  @id @default(cuid())
  transactionId String
  itemId        String
  quantity      Int     @default(1)
  unitPrice     Decimal @db.Decimal(15, 2)
  totalPrice    Decimal @db.Decimal(15, 2)

  transaction CanteenTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  item        CanteenItem        @relation(fields: [itemId], references: [id])
  deletedAt   DateTime?

  @@index([deletedAt])
}

// ============================================
// 21. PROCUREMENT
// ============================================

model PurchaseOrder {
  id           String    @id @default(cuid())
  schoolId     String
  orderNumber  String    @unique
  supplierId   String?
  title        String
  description  String?
  totalAmount  Decimal   @default(0) @db.Decimal(15, 2)
  status       String    @default("DRAFT")
  requestedBy  String?
  approvedBy   String?
  orderDate    DateTime  @default(now())
  expectedDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  school    School              @relation(fields: [schoolId], references: [id])
  supplier  Supplier?           @relation(fields: [supplierId], references: [id])
  items     PurchaseOrderItem[]
  deletedAt DateTime?

  @@index([deletedAt])
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  description     String
  quantity        Int     @default(1)
  unitPrice       Decimal @default(0) @db.Decimal(15, 2)
  totalPrice      Decimal @default(0) @db.Decimal(15, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
