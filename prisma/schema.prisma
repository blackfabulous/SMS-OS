  transportAllowance      Decimal  @default(0) @db.Decimal(15, 2)
  responsibilityAllowance Decimal  @default(0) @db.Decimal(15, 2)
  overtime                Decimal  @default(0) @db.Decimal(15, 2)
  grossPay                Decimal  @default(0) @db.Decimal(15, 2)
  paye                    Decimal  @default(0) @db.Decimal(15, 2)
  nssaEmployee            Decimal  @default(0) @db.Decimal(15, 2)
  nssaEmployer            Decimal  @default(0) @db.Decimal(15, 2)
  aidsLevy                Decimal  @default(0) @db.Decimal(15, 2)
  zimdef                  Decimal  @default(0) @db.Decimal(15, 2)
  pension                 Decimal  @default(0) @db.Decimal(15, 2)
  medicalAid              Decimal  @default(0) @db.Decimal(15, 2)
  funeralPolicy           Decimal  @default(0) @db.Decimal(15, 2)
