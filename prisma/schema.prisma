  EXCUSED
}

enum BeamStatus {
  APPLIED
  PENDING
  APPROVED
  REJECTED
  ACTIVE
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  NEW
  DISPOSED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  PERSONAL
  STUDY
  UNPAID
  COMPASSIONATE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum VisitorStatus {
  ON_CAMPUS
  OFF_CAMPUS
}

enum AccountType {
  CURRENT
  SAVINGS
}

enum ExamLevel {
  GRADE_7
  O_LEVEL
  A_LEVEL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum ResourceType {
  NOTES
  VIDEO
  WORKSHEET
  PAST_EXAM_PAPER
  LINK
  DOCUMENT
}

