  LINK
  DOCUMENT
}

enum AssignmentStatus {
  OPEN
  CLOSED
  GRADING
}

enum PartnerCategory {
  ACCREDITATION
  PARTNER
  AFFILIATION
}

enum ShopOrderStatus {
  PENDING
  PROCESSING
  READY
  COLLECTED
  CANCELLED
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(ADMIN)
  staffId   String?   @unique
  studentId String?   @unique
  parentId  String?   @unique
  schoolId  String
  isActive  Boolean   @default(true)
  lastLogin DateTime? @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)

  staff     Staff?    @relation(fields: [staffId], references: [id])
  student   Student?  @relation(fields: [studentId], references: [id])
  parent    Parent?   @relation(fields: [parentId], references: [id])
  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

// ============================================
// 20. AUDIT LOG
// ============================================

model AuditLog {
  id          String    @id @default(cuid())
  schoolId    String?
  action      String
  entity      String
  entityId    String?
  performedBy String?
  actorId     String?
  details     String?
  beforeValue Json?
  afterValue  Json?
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  deletedAt   DateTime? @db.Timestamptz(3)

  school School? @relation(fields: [schoolId], references: [id])

  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([schoolId])
}

model Outbox {
  id          String       @id @default(cuid())
  schoolId    String?
  topic       String
  payload     Json
  status      OutboxStatus @default(PENDING)
  attempts    Int          @default(0)
  maxAttempts Int          @default(3)
  error       String?
  scheduledAt DateTime     @default(now()) @db.Timestamptz(3)
  createdAt   DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(3)
  deletedAt   DateTime?    @db.Timestamptz(3)
  school      School?      @relation(fields: [schoolId], references: [id])

  @@index([status, scheduledAt])
  @@index([schoolId])
  @@index([deletedAt])
}

model IdempotencyKey {
  id        String   @id @default(cuid())
  scope     String
  key       String
  response  Json?
  expiresAt DateTime @db.Timestamptz(3)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@unique([scope, key])
  @@index([expiresAt])
}

model RateLimitWindow {
  id          String   @id @default(cuid())
  key         String   @unique
  windowStart DateTime @db.Timestamptz(3)
  count       Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  @@index([windowStart])
}

// ============================================
// 20. CANTEEN / TUCKSHOP
// ============================================

model CanteenItem {
  id            String          @id @default(cuid())
  schoolId      String
  name          String
  category      CanteenCategory @default(FOOD)
  price         Decimal         @default(0) @db.Decimal(15, 2)
  costPrice     Decimal         @default(0) @db.Decimal(15, 2)
  stockQuantity Int             @default(0)
  reorderLevel  Int             @default(5)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime        @updatedAt @db.Timestamptz(3)

  school           School                   @relation(fields: [schoolId], references: [id])
  transactionItems CanteenTransactionItem[]
  deletedAt        DateTime?                @db.Timestamptz(3)

  @@index([deletedAt])
}

model CanteenTransaction {
  id                String                   @id @default(cuid())
  schoolId          String
  transactionNumber String                   @unique
  buyerType         BuyerType                @default(STUDENT)
  buyerId           String?
  buyerName         String
  totalAmount       Decimal                  @default(0) @db.Decimal(15, 2)
  paymentMethod     PaymentMethod            @default(CASH)
  status            CanteenTransactionStatus @default(COMPLETED)
  createdAt         DateTime                 @default(now()) @db.Timestamptz(3)

  school    School                   @relation(fields: [schoolId], references: [id])
  items     CanteenTransactionItem[]
  deletedAt DateTime?                @db.Timestamptz(3)

  @@index([deletedAt])
}

model CanteenTransactionItem {
  id            String  @id @default(cuid())
  schoolId      String
  transactionId String
  itemId        String
  quantity      Int     @default(1)
  unitPrice     Decimal @db.Decimal(15, 2)
  totalPrice    Decimal @db.Decimal(15, 2)

  school      School             @relation(fields: [schoolId], references: [id])
  transaction CanteenTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  item        CanteenItem        @relation(fields: [itemId], references: [id])
  deletedAt   DateTime?          @db.Timestamptz(3)

  @@index([deletedAt])
  @@index([schoolId])
}

// ============================================
// 21. PROCUREMENT
// ============================================

model PurchaseOrder {
  id           String              @id @default(cuid())
  schoolId     String
  orderNumber  String              @unique
  supplierId   String?
  title        String
  description  String?
  totalAmount  Decimal             @default(0) @db.Decimal(15, 2)
  status       PurchaseOrderStatus @default(DRAFT)
  requestedBy  String?
  approvedBy   String?
  orderDate    DateTime            @default(now()) @db.Timestamptz(3)
  expectedDate DateTime?           @db.Timestamptz(3)
  createdAt    DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime            @updatedAt @db.Timestamptz(3)

  school    School              @relation(fields: [schoolId], references: [id])
  supplier  Supplier?           @relation(fields: [supplierId], references: [id])
  items     PurchaseOrderItem[]
  deletedAt DateTime?           @db.Timestamptz(3)

  @@index([deletedAt])
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  schoolId        String
  purchaseOrderId String
  description     String
  quantity        Int     @default(1)
  unitPrice       Decimal @default(0) @db.Decimal(15, 2)
  totalPrice      Decimal @default(0) @db.Decimal(15, 2)

  school        School        @relation(fields: [schoolId], references: [id])
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  deletedAt     DateTime?     @db.Timestamptz(3)

  @@index([deletedAt])
  @@index([schoolId])
}

model Requisition {
  id            String            @id @default(cuid())
  schoolId      String
  title         String
  description   String?
  requestedBy   String?
  department    String?
  estimatedCost Decimal?          @db.Decimal(15, 2)
  status        RequisitionStatus @default(PENDING)
  priority      Priority          @default(MEDIUM)
  createdAt     DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime          @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
}

// ============================================
// 22. DOCUMENTS
// ============================================

model Document {
  id          String           @id @default(cuid())
  schoolId    String
  title       String
  category    DocumentCategory @default(GENERAL)
  description String?
  fileName    String
  fileType    FileType         @default(PDF)
  fileSize    Int              @default(0)
  uploadedBy  String?
  tags        String?
  isTemplate  Boolean          @default(false)
  version     Int              @default(1)
  status      DocumentStatus   @default(PENDING)
  createdAt   DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime         @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
}

// ============================================
// 23. ALUMNI
// ============================================

model Alumni {
  id                 String   @id @default(cuid())
  schoolId           String
  firstName          String
  lastName           String
  graduationYear     Int
  email              String?
  phone              String?
  occupation         String?
  company            String?
  location           String?
  isNotable          Boolean  @default(false)
  totalContributions Decimal  @default(0) @db.Decimal(15, 2)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime @updatedAt @db.Timestamptz(3)

  school        School               @relation(fields: [schoolId], references: [id])
  contributions AlumniContribution[]
  deletedAt     DateTime?            @db.Timestamptz(3)

  @@index([deletedAt])
}

model AlumniContribution {
  id               String           @id @default(cuid())
  alumniId         String
  amount           Decimal          @db.Decimal(15, 2)
  contributionType ContributionType @default(DONATION)
  description      String?
  campaign         String?
  date             DateTime         @default(now()) @db.Timestamptz(3)
  createdAt        DateTime         @default(now()) @db.Timestamptz(3)

  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id])
  alumni    Alumni    @relation(fields: [alumniId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
  @@index([schoolId])
}

// ============================================
// 24. SECURITY & VISITORS
// ============================================

model Visitor {
  id           String        @id @default(cuid())
  schoolId     String
  name         String
  idNumber     String?
  purpose      String
  hostPerson   String?
  vehicleReg   String?
  phone        String?
  checkInTime  DateTime      @default(now()) @db.Timestamptz(3)
  checkOutTime DateTime?     @db.Timestamptz(3)
  status       VisitorStatus @default(ON_CAMPUS)
  createdAt    DateTime      @default(now()) @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
}

model SecurityIncident {
  id           String         @id @default(cuid())
  schoolId     String
  incidentType String
  location     String?
  severity     Severity       @default(LOW)
  description  String
  reporter     String?
  status       IncidentStatus @default(OPEN)
  resolution   String?
  createdAt    DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime       @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
}

// ============================================
// 25. E-LEARNING
// ============================================

model Course {
  id                 String   @id @default(cuid())
  schoolId           String
  subjectId          String?
  name               String
  description        String?
  instructor         String?
  enrollmentCount    Int      @default(0)
  syllabusCompletion Float    @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime @updatedAt @db.Timestamptz(3)

  school      School             @relation(fields: [schoolId], references: [id])
  resources   CourseResource[]
  assignments CourseAssignment[]
  deletedAt   DateTime?          @db.Timestamptz(3)

  @@index([deletedAt])
}

model CourseResource {
  id           String       @id @default(cuid())
  courseId     String
  title        String
  resourceType ResourceType @default(NOTES)
  url          String?
  fileSize     Int          @default(0)
  downloads    Int          @default(0)
  uploadedBy   String?
  createdAt    DateTime     @default(now()) @db.Timestamptz(3)

  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id])
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
  @@index([schoolId])
}

model CourseAssignment {
  id               String           @id @default(cuid())
  courseId         String
  title            String
  description      String?
  maxMarks         Float            @default(100)
  dueDate          DateTime?        @db.Timestamptz(3)
  status           AssignmentStatus @default(OPEN)
  submissionsCount Int              @default(0)
  avgScore         Float?
  createdAt        DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(3)

  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id])
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
  @@index([schoolId])
}

// ============================================
// 26. TIMETABLE
// ============================================

model TimetableEntry {
  id        String   @id @default(cuid())
  schoolId  String
  classId   String
  subjectId String
  staffId   String?
  dayOfWeek Int      @default(1)
  period    Int      @default(1)
  room      String?
  startTime String?
  endTime   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  class     Class     @relation(fields: [classId], references: [id])
  subject   Subject   @relation(fields: [subjectId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
}

// ============================================
// 27. WEBSITE CMS
// ============================================

model WebsitePage {
  id               String   @id @default(cuid())
  schoolId         String
  slug             String
  title            String
  content          String
  heroImage        String?
  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?
  schemaMarkup     String?
  isPublished      Boolean  @default(false)
  showInNavigation Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@unique([schoolId, slug])
  @@index([deletedAt])
}

model NewsArticle {
  id              String    @id @default(cuid())
  schoolId        String
  title           String
  slug            String
  excerpt         String?
  content         String
  featuredImage   String?
  category        String    @default("GENERAL")
  authorName      String?
  isPublished     Boolean   @default(false)
  isFeatured      Boolean   @default(false)
  publishedAt     DateTime? @db.Timestamptz(3)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@unique([schoolId, slug])
  @@index([deletedAt])
}

model GalleryImage {
  id          String   @id @default(cuid())
  schoolId    String
  title       String?
  description String?
  imageUrl    String
  category    String   @default("GENERAL")
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
}

// ── Public website: accreditation / partner logos (carousel on the home page) ──
model Partner {
  id         String          @id @default(cuid())
  schoolId   String
  name       String
  logoUrl    String? // image URL; when null the public site renders a text badge
  websiteUrl String?
  category   PartnerCategory @default(PARTNER) // ACCREDITATION | PARTNER | AFFILIATION
  sortOrder  Int             @default(0)
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime        @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([schoolId, isActive])
  @@index([deletedAt])
}

// ── Public website theme & home-page content (one row per school) ──
model SiteTheme {
  id       String @id @default(cuid())
  schoolId String @unique

  // Brand / theme tokens (CSS variables applied to the public site)
  primaryColor   String @default("#047857") // emerald-700
  secondaryColor String @default("#0f766e") // teal-700
  accentColor    String @default("#facc15") // yellow-400
  darkColor      String @default("#022c22") // emerald-950
  headingFont    String @default("Geist")
  bodyFont       String @default("Geist")
  radius         String @default("0.75rem")

  // Hero section
  heroImageUrl       String  @default("/images/campus-hero.jpg")
  heroBadge          String?
  heroHeadline       String? // falls back to school.name
  heroMotto          String? // falls back to school.motto
  heroSubtitle       String?
  heroPrimaryLabel   String  @default("Apply for Admission")
  heroPrimaryHref    String  @default("/admissions/apply")
  heroSecondaryLabel String  @default("Discover Our School")
  heroSecondaryHref  String  @default("/about")

  // Hero colour overlay
  overlayFrom    String @default("#022c22")
  overlayTo      String @default("#134e4a")
  overlayOpacity Int    @default(80) // 0–100

  // Repeating home content stored as JSON strings
  statsJson        String @default("[]") // [{ value, label }]
  valuesJson       String @default("[]") // [{ icon, title, desc }]
  testimonialsJson String @default("[]") // [{ quote, name, role }]

  // About page prose (editable; null → built-in defaults)
  aboutHistory String?
  missionText  String?
  visionText   String?

  // Home section visibility toggles
  showStats        Boolean @default(true)
  showPartners     Boolean @default(true)
  showValues       Boolean @default(true)
  showGallery      Boolean @default(true)
  showTestimonials Boolean @default(true)
  showNews         Boolean @default(true)
  showEvents       Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
}

// ── Public website: frequently-asked questions (admin-editable accordion) ──
model Faq {
  id        String   @id @default(cuid())
  schoolId  String
  question  String
  answer    String
  category  String   @default("GENERAL")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([schoolId, isActive])
  @@index([deletedAt])
}

model SchoolShopItem {
  id            String   @id @default(cuid())
  schoolId      String
  name          String
  description   String?
  category      String   @default("UNIFORM")
  price         Decimal  @default(0) @db.Decimal(15, 2)
  currency      Currency @default(USD)
  imageUrl      String?
  sizes         String?
  colors        String?
  stockQuantity Int      @default(0)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
}

model SchoolShopOrder {
  id          String          @id @default(cuid())
  schoolId    String
  orderNumber String          @unique
  studentId   String?
  parentName  String?
  parentPhone String?
  parentEmail String?
  items       String
  totalAmount Decimal         @default(0) @db.Decimal(15, 2)
  currency    Currency        @default(USD)
  status      ShopOrderStatus @default(PENDING)
  notes       String?
  createdAt   DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime        @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([deletedAt])
}

model SEOSetting {
  id              String   @id @default(cuid())
  schoolId        String
  pageSlug        String
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  schemaMarkup    String?
  canonicalUrl    String?
  robotsDirective String   @default("index, follow")
  createdAt       DateTime @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@unique([schoolId, pageSlug])
  @@index([deletedAt])
}

// ============================================
// 28. PASSWORD RESET
// ============================================

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique // sha256 of the raw token emailed to the user
  expiresAt DateTime  @db.Timestamptz(3)
  usedAt    DateTime? @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)

  @@index([email])
}

// ============================================
// 29. SETTINGS (generic per-school key/value store)
// ============================================

model SchoolSetting {
  id        String   @id @default(cuid())
  schoolId  String
  key       String // registry key, e.g. "grading.passMark"
  category  String // registry category, e.g. "grading"
  value     String // JSON-encoded value, validated against the registry on write
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime? @db.Timestamptz(3)

  @@unique([schoolId, key])
  @@index([schoolId, category])
  @@index([deletedAt])
}
