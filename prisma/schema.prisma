// Zimbabwe School Management System - Database Schema
// Targets PostgreSQL (Supabase managed Postgres) with comprehensive school operations support

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection (PgBouncer, port 6543, ?pgbouncer=true)
  directUrl = env("DIRECT_URL") // direct connection (port 5432) — used for schema ops/migrations
}

// ============================================
// 1. FOUNDATION - School & Academic Structure
// ============================================

model School {
  id                   String   @id @default(cuid())
  name                 String
  code                 String   @unique
  motto                String?
  logo                 String?
  zimsecCentreNumber   String?
  mopseDistrict        String?
  province             String
  schoolType           String   @default("GOVERNMENT")
  ownershipType        String   @default("GOVERNMENT")
  levelType            String   @default("PRIMARY")
  registrationStatus   String   @default("REGISTERED")
  headName             String?
  deputyHeadName       String?
  contactEmail         String?
  contactPhone         String?
  physicalAddress      String?
  gpsLatitude          String?
  gpsLongitude         String?
  catchmentArea        String?
  responsibleAuthority String?
  establishedYear      Int?
  isActive             Boolean  @default(true)
  bankName             String?
  bankAccountNumber    String?
  bankBranch           String?
  taxNumber            String?
  nssaNumber           String?
  zimdefNumber         String?
  sdcChairperson       String?
  sdcSecretary         String?
  sdcTreasurer         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  academicYears         AcademicYear[]
  grades                Grade[]
  subjects              Subject[]
  departments           Department[]
  students              Student[]
  staffMembers          Staff[]
  parents               Parent[]
  feeStructures         FeeStructure[]
  bankAccounts          BankAccount[]
  houses                House[]
  hostels               Hostel[]
  transportRoutes       TransportRoute[]
  vehicles              Vehicle[]
  assets                Asset[]
  suppliers             Supplier[]
  libraryBooks          LibraryBook[]
  sdcMembers            SDCMember[]
  events                SchoolEvent[]
  clubs                 Club[]
  sportsCodes           SportsCode[]
  users                 User[]
  canteenItems          CanteenItem[]
  canteenTransactions   CanteenTransaction[]
  purchaseOrders        PurchaseOrder[]
  requisitions          Requisition[]
  documents             Document[]
  alumni                Alumni[]
  visitors              Visitor[]
  securityIncidents     SecurityIncident[]
  courses               Course[]
  timetableEntries      TimetableEntry[]
  websitePages          WebsitePage[]
  newsArticles          NewsArticle[]
  galleryImages         GalleryImage[]
  shopItems             SchoolShopItem[]
  shopOrders            SchoolShopOrder[]
  seoSettings           SEOSetting[]
  settings              SchoolSetting[]
  partners              Partner[]
  siteTheme             SiteTheme?
  faqs                  Faq[]
  notificationLogs      NotificationLog[]
  notificationTemplates NotificationTemplate[]
  auditLogs             AuditLog[]
  outboxMessages        Outbox[]
  feeInvoices           FeeInvoice[]
  feePayments           FeePayment[]
  invoiceItems          InvoiceItem[]
  paymentAllocations    PaymentAllocation[]
}

model NotificationLog {
  id           String   @id @default(cuid())
  schoolId     String
  channel      String   @default("SMS")
  recipients   Int      @default(1)
  subject      String?
  body         String
  status       String   @default("Delivered")
  deliveryRate Float    @default(100)
  phone        String?
  eventType    String?
  createdAt    DateTime @default(now())

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime?

  @@index([schoolId, createdAt])
  @@index([deletedAt])
}

model NotificationTemplate {
  id         String    @id @default(cuid())
  schoolId   String
  name       String
  category   String    @default("General")
  channels   String    @default("SMS")
  subject    String?
  body       String
  usageCount Int       @default(0)
  lastUsed   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime?

  @@index([schoolId])
  @@index([deletedAt])
}

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school             School              @relation(fields: [schoolId], references: [id])
  terms              Term[]
  studentEnrollments StudentEnrollment[]
  deletedAt          DateTime?

  @@unique([schoolId, name])
  @@index([deletedAt])
}

model Term {
  id             String    @id @default(cuid())
  academicYearId String
  name           String
  termNumber     Int
  startDate      DateTime
  endDate        DateTime
  openingDate    DateTime?
  closingDate    DateTime?
  isCurrent      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  academicYear      AcademicYear @relation(fields: [academicYearId], references: [id])
  attendanceRecords Attendance[]
  assessments       Assessment[]
  feeInvoices       FeeInvoice[]
  deletedAt         DateTime?

  @@unique([academicYearId, termNumber])
  @@index([deletedAt])
}

model Grade {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  level     String   @default("PRIMARY")
  sequence  Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school        School         @relation(fields: [schoolId], references: [id])
  classes       Class[]
  gradeSubjects GradeSubject[]
  feeStructures FeeStructure[]
  deletedAt     DateTime?

  @@unique([schoolId, name])
  @@index([deletedAt])
}

model Class {
  id             String   @id @default(cuid())
  schoolId       String
  gradeId        String
  name           String
  stream         String?
  academicYear   String
  capacity       Int      @default(40)
  classTeacherId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  grade            Grade               @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  enrollments      StudentEnrollment[]
  timetableEntries TimetableEntry[]
  deletedAt        DateTime?

  @@unique([schoolId, gradeId, name, academicYear])
  @@index([deletedAt])
}

model Subject {
  id          String   @id @default(cuid())
  schoolId    String
  code        String
  name        String
  department  String?
  isCore      Boolean  @default(false)
  isPractical Boolean  @default(false)
  passMark    Float    @default(50)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school           School           @relation(fields: [schoolId], references: [id])
  gradeSubjects    GradeSubject[]
  assessments      Assessment[]
  timetableEntries TimetableEntry[]
  deletedAt        DateTime?

  @@unique([schoolId, code])
  @@index([deletedAt])
}

model GradeSubject {
  id             String   @id @default(cuid())
  gradeId        String
  subjectId      String
  isCompulsory   Boolean  @default(true)
  periodsPerWeek Int      @default(5)
  createdAt      DateTime @default(now())

  grade     Grade     @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  subject   Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  deletedAt DateTime?

  @@unique([gradeId, subjectId])
  @@index([deletedAt])
}

model Department {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  headId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime?

  @@index([deletedAt])
}

// ============================================
// 2. LEARNER MANAGEMENT
// ============================================

model Student {
  id                  String           @id @default(cuid())
  schoolId            String
  studentNumber       String
  firstName           String
  lastName            String
  middleName          String?
  preferredName       String?
  dateOfBirth         DateTime
  gender              Gender
  birthCertNumber     String?
  nationalId          String?
  passportNumber      String?
  photo               String?
  religion            String?
  homeLanguage        String?
  languagePreference  String           @default("ENGLISH")
  nationality         String           @default("Zimbabwean")
  bloodGroup          String?
  allergies           String?
  chronicConditions   String?
  medications         String?
  doctorName          String?
  doctorPhone         String?
  enrollmentStatus    EnrollmentStatus @default(ACTIVE)
  boardingStatus      BoardingStatus?
  beamStatus          String?
  isSpecialNeeds      Boolean          @default(false)
  specialNeedsDetails String?
  previousSchool      String?
  admissionDate       DateTime         @default(now())
  transferDate        DateTime?
  exitDate            DateTime?
  exitReason          String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  school              School               @relation(fields: [schoolId], references: [id])
  parentLinks         StudentParent[]
  enrollments         StudentEnrollment[]
  attendanceRecords   Attendance[]
  assessmentMarks     AssessmentMark[]
  feeInvoices         FeeInvoice[]
  feePayments         FeePayment[]
  disciplineRecords   DisciplineRecord[]
  healthRecords       HealthRecord[]
  welfareRecords      WelfareRecord[]
  beamApplication     BeamApplication?
  scholarships        Scholarship[]
  libraryTransactions LibraryTransaction[]
  transportAssignment TransportAssignment?
  boardingAssignment  BoardingAssignment?
  reportCards         ReportCard[]
  zimsecCandidate     ZimsecCandidate?
  user                User?
  deletedAt           DateTime?

  @@unique([schoolId, studentNumber])
  @@index([schoolId])
  @@index([enrollmentStatus])
  @@index([schoolId, enrollmentStatus])
  @@index([deletedAt])
}

model Parent {
  id               String   @id @default(cuid())
  schoolId         String
  title            String?
  firstName        String
  lastName         String
  nationalId       String?
  email            String?
  phone            String
  whatsappNumber   String?
  address          String?
  employer         String?
  occupation       String?
  preferredContact String   @default("SMS")
  isFeeResponsible Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  school         School          @relation(fields: [schoolId], references: [id])
  studentLinks   StudentParent[]
  feePayments    FeePayment[]
  communications Communication[]
  deletedAt      DateTime?

  @@index([schoolId])
  @@index([phone])
  @@index([deletedAt])
}

model StudentParent {
  id                  String   @id @default(cuid())
  studentId           String
  parentId            String
  relationship        String
  isPrimary           Boolean  @default(false)
  isFeeResponsible    Boolean  @default(false)
  hasPickupPermission Boolean  @default(true)
  hasCustody          Boolean  @default(true)
  custodyRestrictions String?
  createdAt           DateTime @default(now())

  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent    Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  deletedAt DateTime?

  @@unique([studentId, parentId])
  @@index([deletedAt])
}

model StudentEnrollment {
  id             String    @id @default(cuid())
  studentId      String
  classId        String
  academicYearId String
  enrollmentDate DateTime  @default(now())
  exitDate       DateTime?
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  student      Student      @relation(fields: [studentId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  deletedAt    DateTime?

  @@unique([studentId, academicYearId])
  @@index([classId, academicYearId])
  @@index([deletedAt])
}

// ============================================
// 3. STAFF & HR
// ============================================

model Staff {
  id                      String    @id @default(cuid())
  schoolId                String
  staffNumber             String
  title                   String?
  firstName               String
  lastName                String
  middleName              String?
  nationalId              String?
  dateOfBirth             DateTime?
  gender                  Gender?
  address                 String?
  phone                   String?
  email                   String?
  nextOfKin               String?
  nextOfKinPhone          String?
  position                String
  department              String?
  staffType               StaffType @default(TEACHING)
  payType                 String    @default("SCHOOL_PAID")
  qualifications          String?
  subjectSpecialisation   String?
  employmentDate          DateTime?
  contractType            String    @default("PERMANENT")
  payrollStatus           String    @default("ACTIVE")
  bankName                String?
  bankAccountNumber       String?
  nssaNumber              String?
  taxNumber               String?
  basicSalary             Decimal   @default(0) @db.Decimal(15, 2)
  housingAllowance        Decimal   @default(0) @db.Decimal(15, 2)
  transportAllowance      Decimal   @default(0) @db.Decimal(15, 2)
  responsibilityAllowance Decimal   @default(0) @db.Decimal(15, 2)
  photo                   String?
  isActive                Boolean   @default(true)
  // Public website ("Our team" on the About page)
  showOnWebsite           Boolean   @default(false)
  websiteBio              String?
  websiteOrder            Int       @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  school              School            @relation(fields: [schoolId], references: [id])
  leaveRecords        LeaveRecord[]
  payslips            Payslip[]
  appraisalRecords    AppraisalRecord[]
  disciplinaryRecords StaffDiscipline[]
  user                User?
  deletedAt           DateTime?

  @@unique([schoolId, staffNumber])
  @@index([deletedAt])
}

// ============================================
// 4. ATTENDANCE
// ============================================

model Attendance {
  id             String           @id @default(cuid())
  studentId      String?
  termId         String
  date           DateTime
  attendanceType String           @default("DAILY")
  status         AttendanceStatus @default(PRESENT)
  remarks        String?
  createdAt      DateTime         @default(now())

  student   Student?  @relation(fields: [studentId], references: [id])
  term      Term      @relation(fields: [termId], references: [id])
  deletedAt DateTime?

  @@index([studentId, date])
  @@index([termId])
  @@index([termId, date])
  @@index([deletedAt])
}

// ============================================
// 5. ASSESSMENT & ACADEMICS
// ============================================

model Assessment {
  id             String    @id @default(cuid())
  schoolId       String
  termId         String
  subjectId      String
  classId        String?
  name           String
  assessmentType String    @default("TEST")
  totalMarks     Float     @default(100)
  weight         Float     @default(1)
  date           DateTime?
  isLocked       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  subject   Subject          @relation(fields: [subjectId], references: [id])
  term      Term             @relation(fields: [termId], references: [id])
  marks     AssessmentMark[]
  deletedAt DateTime?

  @@index([deletedAt])
}

model AssessmentMark {
  id            String   @id @default(cuid())
  assessmentId  String
  studentId     String
  marksObtained Float
  grade         String?
  comments      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])
  deletedAt  DateTime?

  @@unique([assessmentId, studentId])
  @@index([studentId])
  @@index([deletedAt])
}

model ReportCard {
  id                   String    @id @default(cuid())
  studentId            String
  termId               String
  classId              String
  overallGrade         String?
  overallPosition      Int?
  classTeacherComment  String?
  headComment          String?
  attendanceDays       Int?
  daysPresent          Int?
  status               String    @default("DRAFT") // DRAFT, SUBMITTED, COUNTERSIGNED, PUBLISHED
  classTeacherSignedAt DateTime?
  headSignedAt         DateTime?
  isPublished          Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  student   Student   @relation(fields: [studentId], references: [id])
  deletedAt DateTime?

  @@unique([studentId, termId])
  @@index([classId, termId])
  @@index([deletedAt])
}

// ============================================
// 6. FINANCE
// ============================================

model FeeStructure {
  id        String   @id @default(cuid())
  schoolId  String
  gradeId   String
  termId    String?
  name      String
  feeType   String
  amount    Decimal  @db.Decimal(15, 2)
  currency  Currency @default(USD)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School    @relation(fields: [schoolId], references: [id])
  grade     Grade     @relation(fields: [gradeId], references: [id])
  deletedAt DateTime?

  @@index([deletedAt])
}

model FeeInvoice {
  id             String        @id @default(cuid())
  studentId      String
  termId         String
  schoolId       String
  invoiceNumber  String
  totalAmount    Decimal       @db.Decimal(15, 2)
  amountPaid     Decimal       @default(0) @db.Decimal(15, 2)
  balance        Decimal       @db.Decimal(15, 2)
  dueDate        DateTime
  status         InvoiceStatus @default(PENDING)
  lateFeeApplied Boolean       @default(false) // guards against compounding the overdue penalty
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  student     Student             @relation(fields: [studentId], references: [id])
  term        Term                @relation(fields: [termId], references: [id])
  school      School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  allocations PaymentAllocation[]
  payments    FeePayment[]
  items       InvoiceItem[]
  deletedAt   DateTime?

  @@unique([schoolId, invoiceNumber])
  @@index([studentId, status])
  @@index([termId])
  @@index([deletedAt])
  @@index([schoolId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  amount      Decimal  @db.Decimal(15, 2)
  feeType     String
  schoolId    String
  createdAt   DateTime @default(now())

  invoice   FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  deletedAt DateTime?

  @@index([deletedAt])
  @@index([schoolId])
}

model FeePayment {
  id            String        @id @default(cuid())
  studentId     String
  invoiceId     String?
  parentId      String?
  schoolId      String
  receiptNumber String
  amount        Decimal       @db.Decimal(15, 2)
  paymentMethod PaymentMethod @default(CASH)
  currency      Currency      @default(USD)
  exchangeRate  Float         @default(1)
  reference     String?
  isReversed    Boolean       @default(false)
  createdAt     DateTime      @default(now())

  student     Student             @relation(fields: [studentId], references: [id])
  invoice     FeeInvoice?         @relation(fields: [invoiceId], references: [id])
  parent      Parent?             @relation(fields: [parentId], references: [id])
  school      School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  allocations PaymentAllocation[]
  deletedAt   DateTime?

  @@unique([schoolId, receiptNumber])
  @@index([studentId])
  @@index([invoiceId])
  @@index([parentId])
  @@index([deletedAt])
  @@index([schoolId])
}

model PaymentAllocation {
  id          String    @id @default(cuid())
  paymentId   String
  invoiceId   String
  schoolId    String
  amount      Decimal   @db.Decimal(15, 2)
  allocatedAt DateTime  @default(now())
  deletedAt   DateTime?

  payment FeePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  school  School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([invoiceId])
  @@index([schoolId])
  @@index([deletedAt])
}

model BankAccount {
  id            String      @id @default(cuid())
  schoolId      String
  bankName      String
  accountName   String
  accountNumber String
  branch        String?
  branchCode    String?
  accountType   AccountType @default(CURRENT)
  currency      Currency    @default(USD)
  balance       Decimal     @default(0) @db.Decimal(15, 2)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime?

  @@index([deletedAt])
}

model Scholarship {
  id                 String    @id @default(cuid())
  studentId          String
  name               String
  discountPercentage Float
  amount             Decimal?  @db.Decimal(15, 2)
  donor              String?
  startDate          DateTime
  endDate            DateTime?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())

  student   Student   @relation(fields: [studentId], references: [id])
  deletedAt DateTime?

  @@index([deletedAt])
}

// ============================================
// 7. ZIMSEC
// ============================================

model ZimsecCandidate {
  id                 String    @id @default(cuid())
  studentId          String    @unique
  centreNumber       String?
  candidateNumber    String?
  examLevel          ExamLevel
  examYear           Int
  registrationStatus String    @default("PENDING")
  subjects           String?
  totalFees          Decimal   @default(0) @db.Decimal(15, 2)
  feesPaid           Decimal   @default(0) @db.Decimal(15, 2)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  student   Student   @relation(fields: [studentId], references: [id])
  deletedAt DateTime?

  @@index([deletedAt])
}

// ============================================
// 8. BEAM & WELFARE
// ============================================

model BeamApplication {
  id                 String     @id @default(cuid())
  studentId          String     @unique
  applicationDate    DateTime   @default(now())
  status             BeamStatus @default(APPLIED)
  coveredAmount      Decimal    @default(0) @db.Decimal(15, 2)
  outstandingBalance Decimal    @default(0) @db.Decimal(15, 2)
  socialWelfareRef   String?
  guardianSituation  String?
  orphanStatus       String?
  notes              String?
  coverageAppliedAt  DateTime? // set when the approved coverage has been posted to invoices (idempotency)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  student   Student   @relation(fields: [studentId], references: [id])
  deletedAt DateTime?

  @@index([deletedAt])
}

model WelfareRecord {
  id             String   @id @default(cuid())
  studentId      String
  category       String
  description    String?
  actionTaken    String?
  referredTo     String?
  status         String   @default("OPEN")
  isConfidential Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student   Student   @relation(fields: [studentId], references: [id])
  deletedAt DateTime?

  @@index([deletedAt])
}

// ============================================
// 9. DISCIPLINE & HEALTH
// ============================================

model DisciplineRecord {
  id             String   @id @default(cuid())
  studentId      String
  incidentType   String
  description    String
  date           DateTime
  action         String?
  meritPoints    Int      @default(0)
  demeritPoints  Int      @default(0)
  parentNotified Boolean  @default(false)
  status         String   @default("OPEN")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student   Student   @relation(fields: [studentId], references: [id])
  deletedAt DateTime?

  @@index([deletedAt])
}

model HealthRecord {
  id              String   @id @default(cuid())
  studentId       String
  visitType       String
  description     String
  treatment       String?
  medicationGiven String?
  referredTo      String?
  visitDate       DateTime @default(now())
  isConfidential  Boolean  @default(true)
  createdAt       DateTime @default(now())

  student   Student   @relation(fields: [studentId], references: [id])
  deletedAt DateTime?

  @@index([deletedAt])
}

// ============================================
// 10. BOARDING
// ============================================

model Hostel {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  gender    String?
  capacity  Int      @default(50)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  school      School      @relation(fields: [schoolId], references: [id])
  dormitories Dormitory[]
  deletedAt   DateTime?

  @@index([deletedAt])
}

model Dormitory {
  id               String   @id @default(cuid())
  hostelId         String
  name             String
  capacity         Int      @default(20)
  currentOccupancy Int      @default(0)
  createdAt        DateTime @default(now())

  hostel              Hostel               @relation(fields: [hostelId], references: [id])
  boardingAssignments BoardingAssignment[]
  deletedAt           DateTime?

  @@index([deletedAt])
}

model BoardingAssignment {
  id          String    @id @default(cuid())
  studentId   String    @unique
  dormitoryId String
  bedNumber   String?
  startDate   DateTime  @default(now())
  endDate     DateTime?
  status      String    @default("ACTIVE")
