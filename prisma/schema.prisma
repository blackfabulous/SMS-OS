// ── Public website: accreditation / partner logos (carousel on the home page) ──
model Partner {
  id         String          @id @default(cuid())
  schoolId   String
  name       String
  logoUrl    String? // image URL; when null the public site renders a text badge
  websiteUrl String?
  category   PartnerCategory @default(PARTNER) // ACCREDITATION | PARTNER | AFFILIATION
  sortOrder  Int             @default(0)
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  deletedAt DateTime?

  @@index([schoolId, isActive])
  @@index([deletedAt])
}

// ── Public website theme & home-page content (one row per school) ──
model SiteTheme {
  id       String @id @default(cuid())
  schoolId String @unique

  // Brand / theme tokens (CSS variables applied to the public site)
  primaryColor   String @default("#047857") // emerald-700
  secondaryColor String @default("#0f766e") // teal-700
  accentColor    String @default("#facc15") // yellow-400
  darkColor      String @default("#022c22") // emerald-950
  headingFont    String @default("Geist")
  bodyFont       String @default("Geist")
  radius         String @default("0.75rem")

  // Hero section
  heroImageUrl       String  @default("/images/campus-hero.jpg")
  heroBadge          String?
  heroHeadline       String? // falls back to school.name
  heroMotto          String? // falls back to school.motto
  heroSubtitle       String?
  heroPrimaryLabel   String  @default("Apply for Admission")
  heroPrimaryHref    String  @default("/admissions/apply")
  heroSecondaryLabel String  @default("Discover Our School")
  heroSecondaryHref  String  @default("/about")

  // Hero colour overlay
  overlayFrom    String @default("#022c22")
  overlayTo      String @default("#134e4a")
  overlayOpacity Int    @default(80) // 0–100

  // Repeating home content stored as JSON strings
  statsJson        String @default("[]") // [{ value, label }]
  valuesJson       String @default("[]") // [{ icon, title, desc }]
  testimonialsJson String @default("[]") // [{ quote, name, role }]

  // About page prose (editable; null → built-in defaults)
  aboutHistory String?
  missionText  String?
  visionText   String?

  // Home section visibility toggles
  showStats        Boolean @default(true)
  showPartners     Boolean @default(true)
  showValues       Boolean @default(true)
  showGallery      Boolean @default(true)
  showTestimonials Boolean @default(true)
  showNews         Boolean @default(true)
  showEvents       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  deletedAt DateTime?

  @@index([deletedAt])
}

// ── Public website: frequently-asked questions (admin-editable accordion) ──
model Faq {
  id        String   @id @default(cuid())
  schoolId  String
  question  String
  answer    String
  category  String   @default("GENERAL")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  deletedAt DateTime?

  @@index([schoolId, isActive])
  @@index([deletedAt])
}

model SchoolShopItem {
  id            String   @id @default(cuid())
  schoolId      String
  name          String
  description   String?
  category      String   @default("UNIFORM")
  price         Decimal  @default(0) @db.Decimal(15, 2)
  currency      Currency @default(USD)
  imageUrl      String?
  sizes         String?
  colors        String?
  stockQuantity Int      @default(0)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime?

  @@index([deletedAt])
}

model SchoolShopOrder {
  id          String          @id @default(cuid())
  schoolId    String
  orderNumber String          @unique
  studentId   String?
  parentName  String?
  parentPhone String?
  parentEmail String?
  items       String
  totalAmount Decimal         @default(0) @db.Decimal(15, 2)
  currency    Currency        @default(USD)
  status      ShopOrderStatus @default(PENDING)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime?

  @@index([deletedAt])
}

model SEOSetting {
  id              String   @id @default(cuid())
  schoolId        String
  pageSlug        String
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  schemaMarkup    String?
  canonicalUrl    String?
  robotsDirective String   @default("index, follow")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  school    School    @relation(fields: [schoolId], references: [id])
  deletedAt DateTime?

  @@unique([schoolId, pageSlug])
  @@index([deletedAt])
}

// ============================================
// 28. PASSWORD RESET
// ============================================

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique // sha256 of the raw token emailed to the user
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

// ============================================
// 29. SETTINGS (generic per-school key/value store)
// ============================================

model SchoolSetting {
  id        String   @id @default(cuid())
  schoolId  String
  key       String // registry key, e.g. "grading.passMark"
  category  String // registry category, e.g. "grading"
  value     String // JSON-encoded value, validated against the registry on write
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  deletedAt DateTime?

  @@unique([schoolId, key])
  @@index([schoolId, category])
  @@index([deletedAt])
}
