// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// --- NOTES ---
// 1. Every tenant-owned table carries `schoolId` and uses `@@unique([schoolId, <naturalKey>])`.
// 2. Money is `Decimal @db.Decimal(15, 2)` everywhere. No Float for money.
// 3. Soft-delete is `deletedAt DateTime?` with a Prisma extension auto-filtering deletedAt: null.
// 4. Postgres RLS is enabled at the DB level and keyed on `current_setting('app.current_school_id')`.
//    Because PgBouncer/Supabase reuses connections in transaction mode, use `SET LOCAL` inside
//    every transaction, not a session-level `SET`.
// 5. `User` is polymorphic via `personType` + `personId`. The CHECK constraint is enforced by the
//    app layer and optionally by a Postgres CHECK (Prisma can't express polymorphic FKs natively).
// 6. `Invoice` has no `balance` column; balances are derived from `Invoice.totalAmount` - `SUM(PaymentAllocation.amount)`.
// 7. Run `prisma generate` after editing. Use `prisma migrate dev` once migration history is introduced.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // If using Supabase with PgBouncer, also set: DATABASE_URL_UNPOOLED for migrations
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  PARENT
  FINANCE
  OPERATIONS
}

enum PersonType {
  STAFF
  STUDENT
  GUARDIAN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum EnrollmentStatus {
  ENROLLED
  PENDING
  WAITLISTED
  SUSPENDED
  WITHDRAWN
  GRADUATED
  TRANSFERRED
}

enum StaffType {
  TEACHING
  ADMINISTRATIVE
  SUPPORT
  FINANCE
  OPERATIONS
  SECURITY
  CLEANING
  OTHER
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  ECOCASH
  ONEMONEY
  INNBUCKS
  ZIMSWITCH
  PAYNOW
  BEAM
  CARD
  OTHER
}

enum Currency {
  USD
  ZWG
  ZAR
  GBP
  EUR
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
  WRITTEN_OFF
}

enum ReportCardStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum AssessmentType {
  CLASS_TEST
  ASSIGNMENT
  MIDTERM
  FINAL
  PROJECT
  PRACTICAL
  ORAL
  CONTINUOUS_ASSESSMENT
}

enum FeeFrequency {
  ONCE
  TERM
  MONTHLY
  YEARLY
  WEEKLY
  DAILY
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  RETRYING
}

enum ChannelType {
  EMAIL
  SMS
  PUSH
  IN_APP
  WHATSAPP
}

enum OutboxStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum ProcurementStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ORDERED
  RECEIVED
  CANCELLED
}

enum SaleStatus {
  DRAFT
  COMPLETED
  REFUNDED
  CANCELLED
}

// ---------------------------------------------------------------------------
// IDENTITY & ACCESS
// ---------------------------------------------------------------------------

model User {
  id                 String     @id @default(cuid())
  schoolId           String
  email              String
  passwordHash       String?
  emailVerified      DateTime?  @db.Timestamptz()
  role               Role
  personType         PersonType
  personId           String
  image              String?
  isTwoFactorEnabled Boolean    @default(false)
  lastLoginAt        DateTime?  @db.Timestamptz()
  createdAt          DateTime   @default(now()) @db.Timestamptz()
  updatedAt          DateTime   @updatedAt @db.Timestamptz()
  deletedAt          DateTime?  @db.Timestamptz()

  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
  updatedSettings     SchoolSetting[]
  sentMessages        Message[]
  createdPages        Page[]
  createdNewsArticles NewsArticle[]
  createdEvents       Event[]

  // Note: Add a Postgres CHECK constraint (or app-level invariant) ensuring:
  // role=TEACHER/ADMIN -> personType=STAFF, role=STUDENT -> personType=STUDENT, role=PARENT -> personType=GUARDIAN.

  @@unique([schoolId, email])
  @@unique([schoolId, personType, personId])
  @@index([schoolId, personType])
  @@index([schoolId, deletedAt])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  schoolId  String
  userId    String
  token     String    @unique
  expiresAt DateTime  @db.Timestamptz()
  usedAt    DateTime? @db.Timestamptz()
  createdAt DateTime  @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deletedAt DateTime? @db.Timestamptz()

  @@index([schoolId, userId])
  @@index([token])
  @@map("password_reset_tokens")
}

model AuditLog {
  id        String   @id @default(cuid())
  schoolId  String
  actorId   String? // User.id who performed the action
  action    String // e.g. "STUDENT.CREATE"
  entity    String // e.g. "Student"
  entityId  String // row id
  before    Json? // snapshot before
  after     Json? // snapshot after
  metadata  Json? // ip, userAgent, etc.
  createdAt DateTime @default(now()) @db.Timestamptz()

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorId], references: [id], onDelete: SetNull)

  deletedAt DateTime? @db.Timestamptz()

  @@index([schoolId, entity, entityId])
  @@index([schoolId, actorId, createdAt])
  @@index([schoolId, createdAt])
  @@map("audit_logs")
}

model SchoolSetting {
  id          String   @id @default(cuid())
  schoolId    String
  key         String // e.g. "finance.default_currency"
  value       Json // typed value stored as JSON
  updatedById String?
  createdAt   DateTime @default(now()) @db.Timestamptz()
  updatedAt   DateTime @updatedAt @db.Timestamptz()

  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  updatedBy User?  @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  deletedAt DateTime? @db.Timestamptz()

  @@unique([schoolId, key])
  @@index([schoolId])
  @@map("school_settings")
}

// ---------------------------------------------------------------------------
// SCHOOL & CALENDAR
// ---------------------------------------------------------------------------

model School {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  timezone        String    @default("Africa/Harare")
  defaultCurrency Currency  @default(USD)
  logoUrl         String?
  address         String?
  phone           String?
  email           String?
  country         String    @default("Zimbabwe")
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @db.Timestamptz()
  deletedAt       DateTime? @db.Timestamptz()

  users               User[]
  settings            SchoolSetting[]
  auditLogs           AuditLog[]
  academicYears       AcademicYear[]
  terms               Term[]
  holidays            Holiday[]
  departments         Department[]
  houses              House[]
  students            Student[]
  guardians           Guardian[]
  staff               Staff[]
  enrollments         Enrollment[]
  grades              Grade[]
  subjects            Subject[]
  classes             Class[]
  timetableEntries    TimetableEntry[]
  assessments         Assessment[]
  assessmentMarks     AssessmentMark[]
  reportCards         ReportCard[]
  gradingScales       GradingScale[]
  feeStructures       FeeStructure[]
  invoices            Invoice[]
  payments            Payment[]
  bankAccounts        BankAccount[]
  scholarships        Scholarship[]
  beamApplications    BeamApplication[]
  messages            Message[]
  templates           Template[]
  channels            Channel[]
  pages               Page[]
  newsArticles        NewsArticle[]
  events              Event[]
  outbox              Outbox[]
  studentGuardians    StudentGuardian[]
  gradeSubjects       GradeSubject[]
  gradeBands          GradeBand[]
  reportCardItems     ReportCardItem[]
  invoiceItems        InvoiceItem[]
  paymentAllocations  PaymentAllocation[]
  notificationEvents  NotificationEvent[]
  galleryImages       GalleryImage[]
  faqs                Faq[]
  siteTheme           SiteTheme?
  seoSetting          SEOSetting?
  dormitories         Dormitory[]
  transportRoutes     TransportRoute[]
  libraryBooks        LibraryBook[]
  assets              Asset[]
  procurementRequests ProcurementRequest[]
  posItems            POSItem[]
  posSales            POSSale[]
  posSaleLines        POSSaleLine[]
  healthRecords       HealthRecord[]
  disciplineRecords   DisciplineRecord[]
  welfareRecords      WelfareRecord[]
  sdcRecords          SDCRecord[]

  @@index([slug, deletedAt])
  @@map("schools")
}

model AcademicYear {
  id        String    @id @default(cuid())
  schoolId  String
  name      String // e.g. "2026"
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  isCurrent Boolean   @default(false)
  createdAt DateTime  @default(now()) @db.Timestamptz()
  updatedAt DateTime  @updatedAt @db.Timestamptz()
  deletedAt DateTime? @db.Timestamptz()

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms         Term[]
  holidays      Holiday[]
  enrollments   Enrollment[]
  classes       Class[]
  assessments   Assessment[]
  reportCards   ReportCard[]
  feeStructures FeeStructure[]
  invoices      Invoice[]
  scholarships  Scholarship[]

  @@unique([schoolId, name])
  @@index([schoolId, isCurrent])
  @@map("academic_years")
}

model Term {
  id             String    @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String // e.g. "Term 1"
  startDate      DateTime  @db.Date
  endDate        DateTime  @db.Date
  isCurrent      Boolean   @default(false)
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @db.Timestamptz()
  deletedAt      DateTime? @db.Timestamptz()

  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  assessments  Assessment[]
  reportCards  ReportCard[]
  invoices     Invoice[]

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId, isCurrent])
  @@map("terms")
}

model Holiday {
  id             String   @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String
  date           DateTime @db.Date
  description    String?
  createdAt      DateTime @default(now()) @db.Timestamptz()
  updatedAt      DateTime @updatedAt @db.Timestamptz()

  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)

  deletedAt DateTime? @db.Timestamptz()

  @@index([schoolId, date])
  @@map("holidays")
}

model Department {
  id          String    @id @default(cuid())
  schoolId    String
  name        String
  code        String?
  description String?
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  deletedAt   DateTime? @db.Timestamptz()

  school School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staff  Staff[]

  @@unique([schoolId, name])
  @@index([schoolId, deletedAt])
  @@map("departments")
}

model House {
  id        String    @id @default(cuid())
  schoolId  String
  name      String
  color     String?
  createdAt DateTime  @default(now()) @db.Timestamptz()
  updatedAt DateTime  @updatedAt @db.Timestamptz()
  deletedAt DateTime? @db.Timestamptz()

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students Student[]

  @@unique([schoolId, name])
  @@map("houses")
}

// ---------------------------------------------------------------------------
// PEOPLE
// ---------------------------------------------------------------------------

model Student {
  id               String           @id @default(cuid())
  schoolId         String
  studentNumber    String
  firstName        String
  middleName       String?
  lastName         String
  dateOfBirth      DateTime?        @db.Date
  gender           Gender?
  nationalId       String?
  passportNumber   String?
  enrollmentStatus EnrollmentStatus @default(PENDING)
  houseId          String?
  medicalNotes     String?
  address          String?
  createdAt        DateTime         @default(now()) @db.Timestamptz()
  updatedAt        DateTime         @updatedAt @db.Timestamptz()
  deletedAt        DateTime?        @db.Timestamptz()

  school            School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  house             House?             @relation(fields: [houseId], references: [id], onDelete: SetNull)
  guardians         StudentGuardian[]
  enrollments       Enrollment[]
  assessmentMarks   AssessmentMark[]
  reportCards       ReportCard[]
  invoices          Invoice[]
  payments          Payment[]
  beamApplications  BeamApplication[]
  healthRecords     HealthRecord[]
  disciplineRecords DisciplineRecord[]
  welfareRecords    WelfareRecord[]
  sdcRecords        SDCRecord[]

  @@unique([schoolId, studentNumber])
  @@index([schoolId, enrollmentStatus, deletedAt])
  @@index([schoolId, lastName, firstName])
  @@map("students")
}

model Guardian {
  id           String    @id @default(cuid())
  schoolId     String
  firstName    String
  lastName     String
  email        String?
  phone        String?
  phone2       String?
  relationship String? // e.g. "Mother", "Father", "Uncle"
  occupation   String?
  address      String?
  nationalId   String?
  createdAt    DateTime  @default(now()) @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @db.Timestamptz()
  deletedAt    DateTime? @db.Timestamptz()

  school   School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students StudentGuardian[]

  @@index([schoolId, deletedAt])
  @@index([schoolId, phone])
  @@map("guardians")
}

model StudentGuardian {
  id         String    @id @default(cuid())
  schoolId   String
  studentId  String
  guardianId String
  isPrimary  Boolean   @default(false)
  canPickup  Boolean   @default(false)
  createdAt  DateTime  @default(now()) @db.Timestamptz()
  updatedAt  DateTime  @updatedAt @db.Timestamptz()
  deletedAt  DateTime? @db.Timestamptz()

  school   School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([schoolId, studentId, guardianId])
  @@index([schoolId, studentId])
  @@index([schoolId, guardianId])
  @@map("student_guardians")
}

model Staff {
  id             String    @id @default(cuid())
  schoolId       String
  staffNumber    String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  gender         Gender?
  dateOfBirth    DateTime? @db.Date
  nationalId     String?
  staffType      StaffType
  departmentId   String?
  isTeacher      Boolean   @default(false)
  isClassTeacher Boolean   @default(false)
  qualification  String?
  joinedAt       DateTime? @db.Date
  leftAt         DateTime? @db.Date
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @db.Timestamptz()
  deletedAt      DateTime? @db.Timestamptz()

  school                School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  department            Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  classesTaught         Class[]          @relation("ClassTeacher")
  timetableEntries      TimetableEntry[]
  teachingAssessments   Assessment[]     @relation("AssessmentTeacher")
  createdAssessments    Assessment[]     @relation("AssessmentCreatedBy")
  markedAssessmentMarks AssessmentMark[]
  receivedPayments      Payment[]
  generatedReportCards  ReportCard[]

  @@unique([schoolId, staffNumber])
  @@index([schoolId, staffType, deletedAt])
  @@index([schoolId, isTeacher])
  @@map("staff")
}

model Enrollment {
  id             String           @id @default(cuid())
  schoolId       String
  studentId      String
  academicYearId String
  gradeId        String
  classId        String?
  rollNumber     String?
  status         EnrollmentStatus @default(ENROLLED)
  enrolledAt     DateTime         @default(now()) @db.Timestamptz()
  withdrawnAt    DateTime?        @db.Timestamptz()
  createdAt      DateTime         @default(now()) @db.Timestamptz()
  updatedAt      DateTime         @updatedAt @db.Timestamptz()
  deletedAt      DateTime?        @db.Timestamptz()

  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  grade        Grade        @relation(fields: [gradeId], references: [id], onDelete: Restrict)
  class        Class?       @relation(fields: [classId], references: [id], onDelete: SetNull)

  @@unique([schoolId, studentId, academicYearId])
  @@index([schoolId, status, deletedAt])
  @@index([schoolId, classId])
  @@map("enrollments")
}

// ---------------------------------------------------------------------------
// ACADEMICS
// ---------------------------------------------------------------------------

model Grade {
  id          String    @id @default(cuid())
  schoolId    String
  name        String // e.g. "Form 1"
  level       Int // numeric level for ordering
  description String?
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  deletedAt   DateTime? @db.Timestamptz()

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  gradeSubjects GradeSubject[]
  enrollments   Enrollment[]
  classes       Class[]
  assessments   Assessment[]
  feeStructures FeeStructure[]

  @@unique([schoolId, name])
  @@index([schoolId, level])
  @@map("grades")
}

model Subject {
  id          String    @id @default(cuid())
  schoolId    String
  name        String
  code        String?
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  deletedAt   DateTime? @db.Timestamptz()

  school           School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  gradeSubjects    GradeSubject[]
  timetableEntries TimetableEntry[]
  assessments      Assessment[]
  reportCardItems  ReportCardItem[]

  @@unique([schoolId, name])
  @@index([schoolId, code, deletedAt])
  @@map("subjects")
}

model GradeSubject {
  id           String    @id @default(cuid())
  schoolId     String
  gradeId      String
  subjectId    String
  isCore       Boolean   @default(true)
  hoursPerWeek Int?
  createdAt    DateTime  @default(now()) @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @db.Timestamptz()
  deletedAt    DateTime? @db.Timestamptz()

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  grade   Grade   @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([schoolId, gradeId, subjectId])
  @@index([schoolId, gradeId])
  @@map("grade_subjects")
}

model Class {
  id             String    @id @default(cuid())
  schoolId       String
  academicYearId String
  gradeId        String
  name           String // e.g. "Form 1A"
  section        String? // e.g. "A"
  classTeacherId String?
  room           String?
  capacity       Int?
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @db.Timestamptz()
  deletedAt      DateTime? @db.Timestamptz()

  school           School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear     AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  grade            Grade            @relation(fields: [gradeId], references: [id], onDelete: Restrict)
  classTeacher     Staff?           @relation("ClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)
  enrollments      Enrollment[]
  timetableEntries TimetableEntry[]
  assessments      Assessment[]

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId, gradeId, deletedAt])
  @@map("classes")
}

model TimetableEntry {
  id        String    @id @default(cuid())
  schoolId  String
  classId   String
  subjectId String
  teacherId String?
  dayOfWeek Int // 0=Monday, 6=Sunday (or use enum)
  startTime String // HH:MM
  endTime   String // HH:MM
  room      String?
  createdAt DateTime  @default(now()) @db.Timestamptz()
  updatedAt DateTime  @updatedAt @db.Timestamptz()
  deletedAt DateTime? @db.Timestamptz()

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  teacher Staff?  @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  @@index([schoolId, classId, dayOfWeek])
  @@index([schoolId, teacherId])
  @@map("timetable_entries")
}

// ---------------------------------------------------------------------------
// ASSESSMENT
// ---------------------------------------------------------------------------

model GradingScale {
  id        String    @id @default(cuid())
  schoolId  String
  name      String
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now()) @db.Timestamptz()
  updatedAt DateTime  @updatedAt @db.Timestamptz()
  deletedAt DateTime? @db.Timestamptz()

  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  bands       GradeBand[]
  reportCards ReportCard[]

  @@unique([schoolId, name])
  @@index([schoolId, isDefault])
  @@map("grading_scales")
}

model GradeBand {
  id             String   @id @default(cuid())
  schoolId       String
  gradingScaleId String
  minScore       Decimal  @db.Decimal(5, 2)
  maxScore       Decimal  @db.Decimal(5, 2)
  letterGrade    String // e.g. "A"
  gradePoint     Decimal? @db.Decimal(3, 2)
  remark         String? // e.g. "Excellent"
  createdAt      DateTime @default(now()) @db.Timestamptz()
  updatedAt      DateTime @updatedAt @db.Timestamptz()

  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  gradingScale GradingScale @relation(fields: [gradingScaleId], references: [id], onDelete: Cascade)

  deletedAt DateTime? @db.Timestamptz()

  @@unique([schoolId, gradingScaleId, minScore, maxScore])
  @@index([schoolId, gradingScaleId])
  @@map("grade_bands")
}

model Assessment {
  id             String         @id @default(cuid())
  schoolId       String
  academicYearId String
  termId         String
  gradeId        String
  classId        String?
  subjectId      String
  teacherId      String?
  name           String
  type           AssessmentType
  maxScore       Decimal        @db.Decimal(5, 2)
  weight         Decimal        @default("0.00") @db.Decimal(5, 2)
  assessmentDate DateTime?      @db.Date
  description    String?
  createdById    String?
  createdAt      DateTime       @default(now()) @db.Timestamptz()
  updatedAt      DateTime       @updatedAt @db.Timestamptz()
  deletedAt      DateTime?      @db.Timestamptz()

  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  term            Term             @relation(fields: [termId], references: [id], onDelete: Restrict)
  grade           Grade            @relation(fields: [gradeId], references: [id], onDelete: Restrict)
  class           Class?           @relation(fields: [classId], references: [id], onDelete: SetNull)
  subject         Subject          @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  teacher         Staff?           @relation("AssessmentTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  createdBy       Staff?           @relation("AssessmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
