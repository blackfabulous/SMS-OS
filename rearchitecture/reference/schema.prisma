  actionTaken  String?
  recordedById String?
  createdAt    DateTime  @default(now()) @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @db.Timestamptz()
  deletedAt    DateTime? @db.Timestamptz()

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId, incidentDate])
  @@map("discipline_records")
}

model WelfareRecord {
  id          String    @id @default(cuid())
  schoolId    String
  studentId   String
  category    String // e.g. "SCHOLARSHIP", "FOOD", "UNIFORM"
  description String?   @db.Text
  amount      Decimal?  @db.Decimal(15, 2)
  currency    Currency?
  providedAt  DateTime  @default(now()) @db.Timestamptz()
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  deletedAt   DateTime? @db.Timestamptz()

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId, category])
  @@map("welfare_records")
}

model SDCRecord {
  id           String    @id @default(cuid())
  schoolId     String
  studentId    String
  meetingDate  DateTime  @db.Date
  concern      String    @db.Text
  actionPlan   String?   @db.Text
  followUpDate DateTime? @db.Date
  createdById  String?
  createdAt    DateTime  @default(now()) @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @db.Timestamptz()
  deletedAt    DateTime? @db.Timestamptz()

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId, meetingDate])
  @@map("sdc_records")
}
